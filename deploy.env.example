# Копия: deploy.env (в .gitignore). Удалённый VPS через SSH: deploy.bat
#
# SSH user@host для git pull + ship на сервере.
DEPLOY_SSH=user@nodeadline.online

# Каталог репозитория на сервере (cd перед git pull).
DEPLOY_REMOTE_DIR=/root/nodeadline.online

# Куда на сервере rsync кладёт public/ (тот же путь, что в nginx root).
NODEADLINE_LOCAL_DEST=/var/www/nodeadline/public

# Ветка (по умолчанию main).
# DEPLOY_BRANCH=main

# Отключить git push перед SSH: DEPLOY_GIT_PUSH=0
# DEPLOY_GIT_PUSH=1

# Явный ключ SSH (иначе, если есть, берётся %USERPROFILE%\.ssh\id_ed25519):
# DEPLOY_SSH_IDENTITY=%USERPROFILE%\.ssh\id_ed25519
