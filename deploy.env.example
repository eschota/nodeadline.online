# Скопируйте в deploy.env и заполните (deploy.env в .gitignore).
#
# SSH на VPS, где лежит клон репозитория и куда rsync копирует ship (nginx public).

DEPLOY_SSH=user@nodeadline.online
DEPLOY_REMOTE_DIR=/root/nodeadline.online
NODEADLINE_LOCAL_DEST=/var/www/nodeadline/public
DEPLOY_BRANCH=main

# 1 = перед SSH выполнить git push текущей ветки (нужны закоммиченные изменения)
DEPLOY_GIT_PUSH=1
