# Копия: deploy_local.env (в .gitignore). Локальная выкладка: deploy_local.bat без SSH.
#
# Каталог, куда nginx отдаёт статику (должен совпадать с root для eschota.nodeadline.online).
NODEADLINE_LOCAL_DEST=C:\path\to\nginx\public

# Проверка после rsync: curl этого origin и сравнение с version.json на диске.
NODEADLINE_VERIFY_BASE=https://eschota.nodeadline.online

# Если имя не резолвится или нужен явный IP для SNI (см. tools/verify_public_deploy.sh):
# NODEADLINE_VERIFY_RESOLVE_IP=127.0.0.1
